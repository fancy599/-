# LLM（必填，OpenAI 兼容接口）
LLM_API_KEY=sk-your-key-here
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini
# 推理/部分国产模型仅支持 1，报错时可设为 1；留空则先 0.2 失败后自动改 1
# LLM_TEMPERATURE=1

# 应用
DATABASE_URL=sqlite:///./data/ic_review.db
UPLOAD_DIR=./data/uploads
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# 可选：启动时自动写入演示数据
AUTO_SEED=false

# 正式生产链路统一为 Hybrid Pipeline；fast/full 仅作为弃用兼容参数
PIPELINE_MODE=hybrid
TASK_EXECUTOR=local_thread
REDIS_URL=redis://127.0.0.1:6379/0
HYBRID_MAP_WORKERS=3
# 双模型路由（生产建议显式配置）
# Core Analyser：中等规模、高吞吐模型，用于章节并行初审
# CORE_ANALYSER_MODEL=your-medium-model
# CORE_ANALYSER_BASE_URL=https://your-medium-model-gateway/v1
# CORE_ANALYSER_API_KEY=your-medium-model-key
# CORE_ANALYSER_FALLBACK_MODEL=your-medium-fallback-model
# SOEExpertAgent：大型高质量模型，用于最终合规仲裁
# SOE_EXPERT_MODEL=your-large-model
# SOE_EXPERT_BASE_URL=https://your-large-model-gateway/v1
# SOE_EXPERT_API_KEY=your-large-model-key
# SOE_EXPERT_FALLBACK_MODEL=your-large-fallback-model

# 百度智能云·文档解析 / OCR（PDF 识别必填）
PDF_PARSER_PROVIDER=baidu
BAIDU_OCR_API_KEY=your-baidu-api-key
BAIDU_OCR_SECRET_KEY=your-baidu-secret-key

# 联网搜索（可选；用于“通用内控设计体检”兜底时补充外部监管要求依据，默认 Tavily 兼容接口）
# WEB_SEARCH_API_KEY=your-tavily-key
# WEB_SEARCH_BASE_URL=https://api.tavily.com
